<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="icon" href="/assets/icons/brand/favicon.ico" type="image/x-icon" />
    <link rel="stylesheet" href="/assets/styles/site.css" />
</head>
<body class="min-h-screen bg-slate-950 text-slate-100">
    <% const latestQualitySnapshot = dashboardOverview.meta.recentQualitySnapshots[0] || null; %>

    <main class="mx-auto flex min-h-screen w-full max-w-7xl flex-col gap-8 px-6 py-8 lg:px-10">
        <header class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-[radial-gradient(circle_at_top_left,_rgba(34,211,238,0.16),_transparent_38%),radial-gradient(circle_at_bottom_right,_rgba(249,115,22,0.18),_transparent_34%),linear-gradient(180deg,_rgba(15,23,42,0.96)_0%,_rgba(2,6,23,0.98)_100%)] p-8 shadow-2xl shadow-slate-950/50">
            <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(rgba(255,255,255,0.04)_1px,transparent_1px)] bg-[size:28px_28px] opacity-25"></div>
            <div class="relative flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
                <div class="space-y-4">
                    <div class="flex flex-wrap items-center gap-3">
                        <span class="inline-flex rounded-full border border-cyan-400/30 bg-cyan-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-cyan-300">
                            Dashboard operacional
                        </span>
                        <span class="inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-medium text-slate-300">
                            <%= dashboardOverview.lookbackWindowLabel %>
                        </span>
                    </div>

                    <div class="space-y-3">
                        <h1 class="max-w-4xl text-3xl font-semibold tracking-tight text-white lg:text-4xl">
                            Acompanhamento de seguranca, Meta e Dataset Quality em um unico painel.
                        </h1>
                        <p class="max-w-3xl text-sm leading-7 text-slate-300">
                            Sessao ativa para <strong class="text-white"><%= dashboardUsername %></strong>. Ultima leitura gerada em
                            <strong class="text-white"><%= dashboardOverview.generatedAtLabel %></strong>.
                        </p>
                    </div>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row">
                    <a
                        href="/admin"
                        class="inline-flex items-center justify-center rounded-2xl border border-cyan-300/30 bg-cyan-400/10 px-4 py-3 text-sm font-semibold text-cyan-100 transition hover:border-cyan-200/60 hover:bg-cyan-300/15"
                    >
                        Atualizar painel
                    </a>
                    <a
                        href="/api/admin/dashboard-overview"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:border-white/20 hover:bg-white/10"
                    >
                        Ver JSON da API
                    </a>
                    <form action="/admin/logout" method="post">
                        <button
                            type="submit"
                            class="inline-flex w-full items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white transition hover:border-orange-300/50 hover:bg-orange-400/10 sm:w-auto"
                        >
                            Sair da dashboard
                        </button>
                    </form>
                </div>
            </div>
        </header>

        <% if (snapshotFeedback) { %>
            <section
                class="rounded-3xl border px-5 py-4 text-sm leading-6 <%= snapshotFeedback.tone === 'success' ? 'border-emerald-400/30 bg-emerald-400/10 text-emerald-100' : snapshotFeedback.tone === 'warning' ? 'border-amber-400/30 bg-amber-400/10 text-amber-100' : 'border-rose-400/30 bg-rose-400/10 text-rose-100' %>"
            >
                <%= snapshotFeedback.message %>
            </section>
        <% } %>

        <% if (!dashboardOverview.database.available) { %>
            <section class="rounded-3xl border border-amber-400/30 bg-amber-400/10 px-5 py-4 text-sm leading-6 text-amber-100">
                <strong class="text-white">Banco indisponivel no momento.</strong>
                <span class="block">
                    <%= dashboardOverview.database.errorMessage || 'Configure o DATABASE_URL e aplique a migration para liberar as metricas persistidas.' %>
                </span>
            </section>
        <% } %>

        <% if (sessionWasRefreshed) { %>
            <section class="rounded-3xl border border-cyan-400/30 bg-cyan-400/10 px-5 py-4 text-sm leading-6 text-cyan-100">
                A sessao administrativa foi renovada automaticamente pelo refresh token sem interromper o painel.
            </section>
        <% } %>

        <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Eventos Meta</p>
                <p class="mt-4 text-3xl font-semibold text-white"><%= dashboardOverview.summary.totalMetaEventsCount %></p>
                <p class="mt-2 text-sm text-slate-400">Total processado na janela atual.</p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Leads registrados</p>
                <p class="mt-4 text-3xl font-semibold text-white"><%= dashboardOverview.summary.leadEventsCount %></p>
                <p class="mt-2 text-sm text-slate-400">Cliques e envios rastreados como Lead.</p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Taxa de sucesso Meta</p>
                <p class="mt-4 text-3xl font-semibold text-white"><%= dashboardOverview.summary.metaEventsSuccessRatePercentage %>%</p>
                <p class="mt-2 text-sm text-slate-400"><%= dashboardOverview.summary.acceptedMetaEventsCount %> eventos aceitos pela API.</p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Falhas Meta</p>
                <p class="mt-4 text-3xl font-semibold text-white"><%= dashboardOverview.summary.failedMetaEventsCount %></p>
                <p class="mt-2 text-sm text-slate-400">Erros de requisicao, validacao ou configuracao.</p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Sessoes admin ativas</p>
                <p class="mt-4 text-3xl font-semibold text-white"><%= dashboardOverview.summary.activeAdminSessionsCount %></p>
                <p class="mt-2 text-sm text-slate-400">Sessoes nao revogadas e ainda validas.</p>
            </article>

            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Alertas de seguranca</p>
                <p class="mt-4 text-3xl font-semibold text-white"><%= dashboardOverview.summary.securityAlertsCount %></p>
                <p class="mt-2 text-sm text-slate-400"><%= dashboardOverview.summary.unauthorizedAccessCount %> acessos nao autorizados detectados.</p>
            </article>
        </section>

        <section class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                    <div class="space-y-2">
                        <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Saude da integracao Meta</p>
                        <h2 class="text-2xl font-semibold text-white">Status tecnico da camada de conversao</h2>
                    </div>
                    <span class="inline-flex w-fit rounded-full border border-white/10 bg-white/5 px-3 py-2 text-xs font-medium text-slate-300">
                        Pixel <%= dashboardOverview.meta.health.pixel_id %>
                    </span>
                </div>

                <dl class="mt-6 grid gap-4 sm:grid-cols-2">
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                        <dt class="text-xs uppercase tracking-[0.2em] text-slate-400">Versao da API</dt>
                        <dd class="mt-2 text-lg font-semibold text-white"><%= dashboardOverview.meta.health.api_version %></dd>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                        <dt class="text-xs uppercase tracking-[0.2em] text-slate-400">Token de acesso</dt>
                        <dd class="mt-2 text-lg font-semibold <%= dashboardOverview.meta.health.access_token_configured ? 'text-emerald-300' : 'text-amber-300' %>">
                            <%= dashboardOverview.meta.health.access_token_configured ? 'Configurado' : 'Pendente' %>
                        </dd>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                        <dt class="text-xs uppercase tracking-[0.2em] text-slate-400">Codigo de teste</dt>
                        <dd class="mt-2 text-lg font-semibold <%= dashboardOverview.meta.health.test_event_code_configured ? 'text-cyan-300' : 'text-slate-200' %>">
                            <%= dashboardOverview.meta.health.test_event_code_configured ? 'Ativo' : 'Nao informado' %>
                        </dd>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                        <dt class="text-xs uppercase tracking-[0.2em] text-slate-400">Banco</dt>
                        <dd class="mt-2 text-lg font-semibold <%= dashboardOverview.database.available ? 'text-emerald-300' : 'text-amber-300' %>">
                            <%= dashboardOverview.database.statusLabel %>
                        </dd>
                    </div>
                </dl>
            </article>

            <aside class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <div class="space-y-2">
                    <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Sessao autenticada</p>
                    <h2 class="text-2xl font-semibold text-white">Contexto administrativo</h2>
                </div>

                <dl class="mt-6 grid gap-4">
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                        <dt class="text-xs uppercase tracking-[0.2em] text-slate-400">Usuario</dt>
                        <dd class="mt-2 text-base font-semibold text-white"><%= dashboardUsername %></dd>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                        <dt class="text-xs uppercase tracking-[0.2em] text-slate-400">Emitido em</dt>
                        <dd class="mt-2 text-base font-semibold text-white"><%= sessionIssuedAt %></dd>
                    </div>
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                        <dt class="text-xs uppercase tracking-[0.2em] text-slate-400">Expira em</dt>
                        <dd class="mt-2 text-base font-semibold text-white"><%= sessionExpiresAt %></dd>
                    </div>
                </dl>
            </aside>
        </section>

        <section class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <div class="space-y-2">
                    <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Tendencia diaria</p>
                    <h2 class="text-2xl font-semibold text-white">Atividade por dia</h2>
                </div>

                <div class="mt-6 space-y-4">
                    <% dashboardOverview.trend.dailyActivity.forEach(dailyActivityItem => { %>
                        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                                <div>
                                    <p class="text-sm font-semibold text-white"><%= dailyActivityItem.dateLabel %></p>
                                    <p class="text-xs text-slate-400"><%= dailyActivityItem.metaEventsCount %> eventos Meta e <%= dailyActivityItem.securityAlertsCount %> alertas</p>
                                </div>
                                <div class="grid gap-2 sm:min-w-[280px]">
                                    <div>
                                        <div class="mb-1 flex items-center justify-between text-xs text-slate-400">
                                            <span>Meta</span>
                                            <span><%= dailyActivityItem.metaEventsCount %></span>
                                        </div>
                                        <div class="h-2 rounded-full bg-slate-800">
                                            <div class="h-2 rounded-full bg-cyan-300" style="width: <%= dailyActivityItem.metaEventsWidthPercentage %>%"></div>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="mb-1 flex items-center justify-between text-xs text-slate-400">
                                            <span>Alertas</span>
                                            <span><%= dailyActivityItem.securityAlertsCount %></span>
                                        </div>
                                        <div class="h-2 rounded-full bg-slate-800">
                                            <div class="h-2 rounded-full bg-orange-300" style="width: <%= dailyActivityItem.securityAlertsWidthPercentage %>%"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </article>

            <aside class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <div class="space-y-2">
                    <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Distribuicao</p>
                    <h2 class="text-2xl font-semibold text-white">Eventos mais frequentes</h2>
                </div>

                <% if (dashboardOverview.trend.eventBreakdown.length > 0) { %>
                    <div class="mt-6 space-y-3">
                        <% dashboardOverview.trend.eventBreakdown.forEach(eventBreakdownItem => { %>
                            <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
                                <div class="flex items-center justify-between gap-4">
                                    <div>
                                        <p class="text-sm font-semibold text-white"><%= eventBreakdownItem.eventName %></p>
                                        <p class="text-xs text-slate-400">Ocorrencias no periodo</p>
                                    </div>
                                    <span class="text-lg font-semibold text-cyan-300"><%= eventBreakdownItem.count %></span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="mt-6 rounded-2xl border border-dashed border-white/10 bg-white/5 px-4 py-6 text-sm text-slate-400">
                        Ainda nao ha eventos suficientes para exibir a distribuicao.
                    </div>
                <% } %>
            </aside>
        </section>

        <section class="grid gap-6 xl:grid-cols-2">
            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <div class="space-y-2">
                    <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Eventos recentes</p>
                    <h2 class="text-2xl font-semibold text-white">Meta Conversions API</h2>
                </div>

                <% if (dashboardOverview.trend.recentMetaEvents.length > 0) { %>
                    <div class="mt-6 overflow-x-auto">
                        <table class="min-w-full text-left text-sm">
                            <thead class="text-xs uppercase tracking-[0.18em] text-slate-500">
                                <tr>
                                    <th class="pb-3 pr-4">Horario</th>
                                    <th class="pb-3 pr-4">Evento</th>
                                    <th class="pb-3 pr-4">Status</th>
                                    <th class="pb-3 pr-4">Pagina</th>
                                    <th class="pb-3">Conteudo</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/10">
                                <% dashboardOverview.trend.recentMetaEvents.forEach(metaEventItem => { %>
                                    <tr class="align-top text-slate-300">
                                        <td class="py-3 pr-4"><%= metaEventItem.createdAtLabel %></td>
                                        <td class="py-3 pr-4">
                                            <div class="space-y-1">
                                                <p class="font-semibold text-white"><%= metaEventItem.eventName %></p>
                                                <p class="text-xs text-slate-500"><%= metaEventItem.planInterest %></p>
                                            </div>
                                        </td>
                                        <td class="py-3 pr-4">
                                            <span class="inline-flex rounded-full border px-3 py-1 text-xs font-medium <%= metaEventItem.statusTone === 'success' ? 'border-emerald-400/30 bg-emerald-400/10 text-emerald-200' : metaEventItem.statusTone === 'warning' ? 'border-amber-400/30 bg-amber-400/10 text-amber-200' : metaEventItem.statusTone === 'danger' ? 'border-rose-400/30 bg-rose-400/10 text-rose-200' : 'border-white/10 bg-white/5 text-slate-300' %>">
                                                <%= metaEventItem.statusLabel %>
                                            </span>
                                        </td>
                                        <td class="py-3 pr-4"><%= metaEventItem.pageType %></td>
                                        <td class="py-3">
                                            <div class="space-y-1">
                                                <p><%= metaEventItem.contentName %></p>
                                                <p class="text-xs text-slate-500">HTTP <%= metaEventItem.httpStatus || '-' %></p>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="mt-6 rounded-2xl border border-dashed border-white/10 bg-white/5 px-4 py-6 text-sm text-slate-400">
                        Nenhum evento Meta foi encontrado no banco para este painel.
                    </div>
                <% } %>
            </article>

            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <div class="space-y-2">
                    <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Auditoria recente</p>
                    <h2 class="text-2xl font-semibold text-white">Seguranca administrativa</h2>
                </div>

                <% if (dashboardOverview.trend.recentSecurityEvents.length > 0) { %>
                    <div class="mt-6 overflow-x-auto">
                        <table class="min-w-full text-left text-sm">
                            <thead class="text-xs uppercase tracking-[0.18em] text-slate-500">
                                <tr>
                                    <th class="pb-3 pr-4">Horario</th>
                                    <th class="pb-3 pr-4">Evento</th>
                                    <th class="pb-3 pr-4">Usuario</th>
                                    <th class="pb-3">Origem</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/10">
                                <% dashboardOverview.trend.recentSecurityEvents.forEach(securityEventItem => { %>
                                    <tr class="align-top text-slate-300">
                                        <td class="py-3 pr-4"><%= securityEventItem.createdAtLabel %></td>
                                        <td class="py-3 pr-4">
                                            <div class="space-y-1">
                                                <span class="inline-flex rounded-full border px-3 py-1 text-xs font-medium <%= securityEventItem.tone === 'success' ? 'border-emerald-400/30 bg-emerald-400/10 text-emerald-200' : securityEventItem.tone === 'warning' ? 'border-amber-400/30 bg-amber-400/10 text-amber-200' : 'border-rose-400/30 bg-rose-400/10 text-rose-200' %>">
                                                    <%= securityEventItem.success ? 'Sucesso' : 'Alerta' %>
                                                </span>
                                                <p class="font-semibold text-white"><%= securityEventItem.eventTypeLabel %></p>
                                            </div>
                                        </td>
                                        <td class="py-3 pr-4"><%= securityEventItem.dashboardUsername %></td>
                                        <td class="py-3"><%= securityEventItem.ipAddress %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="mt-6 rounded-2xl border border-dashed border-white/10 bg-white/5 px-4 py-6 text-sm text-slate-400">
                        Nenhum evento de seguranca foi persistido ainda.
                    </div>
                <% } %>
            </article>
        </section>

        <section class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <div class="space-y-2">
                    <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Dataset Quality</p>
                    <h2 class="text-2xl font-semibold text-white">Registrar snapshot manual</h2>
                    <p class="text-sm leading-6 text-slate-400">
                        Enquanto a leitura automatica nao entra na proxima fase, voce pode salvar manualmente o estado visto no Gerenciador de Eventos da Meta.
                    </p>
                </div>

                <form class="mt-6 space-y-4" action="/admin/meta-quality-snapshots" method="post" novalidate>
                    <div class="grid gap-4 sm:grid-cols-2">
                        <div class="space-y-2">
                            <label class="text-sm font-medium text-slate-200" for="dataset-id">Dataset ID</label>
                            <input
                                id="dataset-id"
                                name="datasetId"
                                type="text"
                                class="w-full rounded-2xl border border-white/10 bg-slate-950 px-4 py-3 text-sm text-white outline-none transition focus:border-cyan-300/60"
                                placeholder="Opcional"
                            />
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-medium text-slate-200" for="snapshot-source">Origem</label>
                            <input
                                id="snapshot-source"
                                name="source"
                                type="text"
                                value="manual"
                                class="w-full rounded-2xl border border-white/10 bg-slate-950 px-4 py-3 text-sm text-white outline-none transition focus:border-cyan-300/60"
                                required
                            />
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-medium text-slate-200" for="quality-score">Quality score</label>
                            <input
                                id="quality-score"
                                name="qualityScore"
                                type="number"
                                min="0"
                                max="100"
                                class="w-full rounded-2xl border border-white/10 bg-slate-950 px-4 py-3 text-sm text-white outline-none transition focus:border-cyan-300/60"
                                placeholder="0 a 100"
                            />
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-medium text-slate-200" for="matching-status">Matching status</label>
                            <input
                                id="matching-status"
                                name="matchingStatus"
                                type="text"
                                class="w-full rounded-2xl border border-white/10 bg-slate-950 px-4 py-3 text-sm text-white outline-none transition focus:border-cyan-300/60"
                                placeholder="Ex.: Good"
                            />
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-medium text-slate-200" for="quality-status">Quality status</label>
                        <input
                            id="quality-status"
                            name="qualityStatus"
                            type="text"
                            class="w-full rounded-2xl border border-white/10 bg-slate-950 px-4 py-3 text-sm text-white outline-none transition focus:border-cyan-300/60"
                            placeholder="Ex.: Healthy"
                        />
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-medium text-slate-200" for="diagnostics-json">Diagnosticos em JSON</label>
                        <textarea
                            id="diagnostics-json"
                            name="diagnosticsJson"
                            rows="6"
                            class="w-full rounded-2xl border border-white/10 bg-slate-950 px-4 py-3 text-sm text-white outline-none transition focus:border-cyan-300/60"
                            placeholder='{"observacao":"Preencher com o resumo visto na Meta"}'
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="inline-flex items-center justify-center rounded-2xl bg-orange-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-orange-400"
                    >
                        Salvar snapshot
                    </button>
                </form>
            </article>

            <article class="rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-lg shadow-slate-950/20">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                    <div class="space-y-2">
                        <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Historico recente</p>
                        <h2 class="text-2xl font-semibold text-white">Snapshots de qualidade</h2>
                    </div>
                    <% if (latestQualitySnapshot) { %>
                        <span class="inline-flex w-fit rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-2 text-xs font-semibold text-cyan-200">
                            Ultimo score: <%= latestQualitySnapshot.qualityScore !== null ? `${latestQualitySnapshot.qualityScore}%` : 'sem nota' %>
                        </span>
                    <% } %>
                </div>

                <% if (dashboardOverview.meta.recentQualitySnapshots.length > 0) { %>
                    <div class="mt-6 space-y-4">
                        <% dashboardOverview.meta.recentQualitySnapshots.forEach(qualitySnapshotItem => { %>
                            <article class="rounded-2xl border border-white/10 bg-white/5 p-4">
                                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                                    <div class="space-y-1">
                                        <p class="text-sm font-semibold text-white"><%= qualitySnapshotItem.createdAtLabel %></p>
                                        <p class="text-xs text-slate-400">
                                            Fonte <%= qualitySnapshotItem.source %> | Dataset <%= qualitySnapshotItem.datasetId %>
                                        </p>
                                    </div>
                                    <div class="grid gap-1 text-sm text-slate-300 sm:text-right">
                                        <span>Score: <strong class="text-white"><%= qualitySnapshotItem.qualityScore !== null ? `${qualitySnapshotItem.qualityScore}%` : '-' %></strong></span>
                                        <span>Status: <strong class="text-white"><%= qualitySnapshotItem.qualityStatus %></strong></span>
                                        <span>Matching: <strong class="text-white"><%= qualitySnapshotItem.matchingStatus %></strong></span>
                                    </div>
                                </div>

                                <% if (qualitySnapshotItem.diagnosticsPreview) { %>
                                    <details class="mt-4 rounded-2xl border border-white/10 bg-slate-950/60 p-4">
                                        <summary class="cursor-pointer text-sm font-medium text-slate-200">Ver diagnosticos</summary>
                                        <pre class="mt-3 overflow-x-auto whitespace-pre-wrap text-xs leading-6 text-slate-400"><%= qualitySnapshotItem.diagnosticsPreview %></pre>
                                    </details>
                                <% } %>
                            </article>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="mt-6 rounded-2xl border border-dashed border-white/10 bg-white/5 px-4 py-6 text-sm text-slate-400">
                        Ainda nao existe snapshot salvo. Assim que voce registrar o primeiro, ele aparecera aqui para acompanhamento.
                    </div>
                <% } %>
            </article>
        </section>
    </main>
</body>
</html>
